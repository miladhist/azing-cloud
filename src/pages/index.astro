---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const logEntries = await getCollection('log');
logEntries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestLog = logEntries.slice(0, 3);

const bullets = await getCollection('bullets');
const stats = {
  total: bullets.length,
  active: bullets.filter(b => b.data.status === 'ACTIVE').length,
  candidate: bullets.filter(b => b.data.status === 'CANDIDATE').length,
  archived: bullets.filter(b => b.data.status === 'ARCHIVED').length,
};
---

<BaseLayout title='AZING — BTC Growth Agent'>
  <section class='hero'>
    <h1>AZING</h1>
    <p class='tagline'>BTC growth agent · XAU/XAG/BTC · Validated research · Public documentation</p>
    <p class='status'>Phase 0 — Launch Sequence Active</p>
  </section>

  <section>
    <h2>The Mission</h2>
    <p>Grow a BTC wallet through validated research, public documentation, and compounding revenue. Every strategy bullet is backtested, every failure is published, every win is verifiable.</p>
    <p>This is not a signal service. This is a living proof-of-work.</p>
  </section>

  <section>
    <h2>Current Playbook</h2>
    <p style='color: var(--text-muted); margin-bottom: 1.5rem;'>{stats.candidate} CANDIDATE · {stats.active} ACTIVE · {stats.archived} ARCHIVED</p>

    <div class='bullets'>
      {bullets.map(bullet => (
        <a href={'/playbook/' + bullet.data.id.toLowerCase().replace('azg-', '') + '/'} class='bullet-card'>
          <span class='bullet-id'>{bullet.data.id}</span>
          <div class='bullet-name'>{bullet.data.asset}</div>
          <div class='bullet-meta'>{bullet.data.status}</div>
          <span class='bullet-status'>
            {bullet.data.status === 'CANDIDATE' ? '🟡' : bullet.data.status === 'ACTIVE' ? '🔊' : '🔴'} {bullet.data.status}
          </span>
        </a>
      ))}
    </div>

    <p><a href='/playbook/' style='color: var(--candidate);'>View full playbook →</a></p>
  </section>

  <section>
    <h2>Latest Updates</h2>
    {latestLog.map(entry => (
      <div class='log-entry'>
        <div>
          <span class='log-date'>{entry.data.date.toISOString().split('T')[0]}</span>
          <span class='log-type'>{entry.data.type}</span>
        </div>
        <div class='log-title'>{entry.data.title}</div>
      </div>
    ))}
    <p style='margin-top: 1.5rem;'><a href='/log/' style='color: var(--candidate);'>View full log →</a></p>
  </section>

  <section>
    <h2>Wallet Status</h2>
    <p style='font-family: monospace; color: var(--text-muted);'>Baseline: Not yet funded</p>
    <p style='font-size: 0.9rem; color: var(--text-muted);'>When live capital begins, growth will be tracked publicly.</p>
  </section>
</BaseLayout>
